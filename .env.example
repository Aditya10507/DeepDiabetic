# Django Settings
# SECURITY: Change SECRET_KEY to a random string in production
# Use: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=generate-a-random-key-in-production
DEBUG=False

# Deployment (Render.io)
RENDER_EXTERNAL_HOSTNAME=your-render-hostname.onrender.com

# Additional Allowed Hosts (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration
# Default is SQLite. Set DB_ENGINE to switch to PostgreSQL or MySQL
DB_ENGINE=sqlite
# For PostgreSQL:
# DB_ENGINE=postgresql
# DB_NAME=diabetic_db
# DB_USER=postgres_user
# DB_PASSWORD=secure_password
# DB_HOST=db.example.com
# DB_PORT=5432
# DB_SSLMODE=require
# DB_SSLROOTCERT=/path/to/root.crt
# DB_CONN_MAX_AGE=60

# Azure Database for PostgreSQL
# You can either use the split variables below or a single Azure-generated connection string.
# AZURE_POSTGRESQL_CONNECTIONSTRING=host=<server>.postgres.database.azure.com port=5432 dbname=<database> sslmode=require user=<username> password=<password>
# AZURE_POSTGRESQL_HOST=<server>.postgres.database.azure.com
# AZURE_POSTGRESQL_NAME=<database>
# AZURE_POSTGRESQL_USER=<username>
# AZURE_POSTGRESQL_PASSWORD=<password>
# AZURE_POSTGRESQL_PORT=5432
# AZURE_POSTGRESQL_SSLMODE=require
# AZURE_POSTGRESQL_SSLROOTCERT=/path/to/root.crt

# Generic URL-style connection string support
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# MySQL Configuration (if using MySQL)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=diabetic

# Application Data Directory
APP_DATA_DIR=./data

# App Database Backend
APP_DB_BACKEND=sqlite
