# Django Settings
# SECURITY: Change SECRET_KEY to a random string in production
# Use: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=generate-a-random-key-in-production
DEBUG=False

# Deployment (Render.io)
RENDER_EXTERNAL_HOSTNAME=your-render-hostname.onrender.com

# Additional Allowed Hosts (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost

# Database Configuration
# Default is SQLite. Set DB_ENGINE to switch to PostgreSQL or MySQL
DB_ENGINE=sqlite
# For PostgreSQL:
# DB_ENGINE=postgresql
# DB_NAME=diabetic_db
# DB_USER=postgres_user
# DB_PASSWORD=secure_password
# DB_HOST=db.example.com
# DB_PORT=5432
# DB_SSLMODE=require

# MySQL Configuration (if using MySQL)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=diabetic

# Application Data Directory
APP_DATA_DIR=./data

# App Database Backend
APP_DB_BACKEND=sqlite
